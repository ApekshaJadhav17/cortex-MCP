{
  "manifest_version": 3,
  "name": "Cortex",
  "version": "1.1.0",
  "description": "Save any page to your Cortex second brain. Search recent saves and open the app without leaving your browser.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://localhost:8000/*", "http://localhost:5173/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
